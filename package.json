{
  "name": "inline-markers",
  "displayName": "Inline Markers",
  "version": "0.1.0",
  "description": "",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/f0reth/inline-markers"
  },
  "publisher": "f0reth",
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch",
    "package": "pnpm run lint && node esbuild.js --production",
    "lint": "oxlint --type-aware --type-check",
    "fmt": "oxfmt",
    "bench": "node esbuild.js --bench && vscode-test --config .vscode-test.mjs --label bench",
    "test": "pnpm run compile && vscode-test --label test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "typescript": "^6.0.3"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "inline-markers",
          "title": "Inline Markers",
          "icon": "images/markers-sidebar.svg"
        }
      ]
    },
    "views": {
      "inline-markers": [
        {
          "id": "inline-markers.markers",
          "name": "Markers"
        }
      ]
    },
    "commands": [
      {
        "command": "inline-markers.bookmark.toggle",
        "title": "Toggle Bookmark",
        "category": "Inline Markers"
      },
      {
        "command": "inline-markers.bookmark.navigateNext",
        "title": "Next Bookmark",
        "category": "Inline Markers"
      },
      {
        "command": "inline-markers.bookmark.navigatePrevious",
        "title": "Previous Bookmark",
        "category": "Inline Markers"
      },
      {
        "command": "inline-markers.bookmark.clearAll",
        "title": "Clear All Bookmarks",
        "category": "Inline Markers"
      },
      {
        "command": "inline-markers.bookmark.deleteItem",
        "title": "Delete Bookmark",
        "icon": "$(close)",
        "category": "Inline Markers"
      },
      {
        "command": "inline-markers.bookmark.clearFile",
        "title": "Clear File Bookmarks",
        "category": "Inline Markers"
      },
      {
        "command": "inline-markers.markers.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Inline Markers"
      }
    ],
    "keybindings": [
      {
        "command": "inline-markers.bookmark.toggle",
        "key": "ctrl+alt+k",
        "when": "editorTextFocus"
      },
      {
        "command": "inline-markers.bookmark.navigateNext",
        "key": "ctrl+alt+l",
        "when": "editorTextFocus"
      },
      {
        "command": "inline-markers.bookmark.navigatePrevious",
        "key": "ctrl+alt+j",
        "when": "editorTextFocus"
      },
      {
        "command": "inline-markers.bookmark.clearFile",
        "key": "ctrl+alt+shift+k",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "inline-markers.markers.refresh",
          "when": "view == inline-markers.markers",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "inline-markers.bookmark.toggle",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "inline-markers.bookmark.deleteItem",
          "when": "viewItem == bookmarkItem",
          "group": "inline"
        },
        {
          "command": "inline-markers.bookmark.clearFile",
          "when": "viewItem == bookmarkFile",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Inline Markers",
      "properties": {
        "inline-markers.gutter.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable diagnostic gutter icons."
        },
        "inline-markers.diagnosticLine.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable diagnostic line messages."
        },
        "inline-markers.diagnosticLine.errorLabelBg": {
          "type": "string",
          "default": "#d32f2f88",
          "description": "Background color for error diagnostic lines."
        },
        "inline-markers.diagnosticLine.warnLabelBg": {
          "type": "string",
          "default": "#ff980088",
          "description": "Background color for warning diagnostic lines."
        },
        "inline-markers.diagnosticLine.errFontColor": {
          "type": "string",
          "default": "#efefef",
          "description": "Text color for error diagnostic lines."
        },
        "inline-markers.diagnosticLine.warnFontColor": {
          "type": "string",
          "default": "#000000",
          "description": "Text color for warning diagnostic lines."
        },
        "inline-markers.diagnosticLine.maxLineLength": {
          "type": "number",
          "default": 120,
          "description": "Maximum length of diagnostic messages."
        },
        "inline-markers.comments.tags": {
          "type": "array",
          "default": [
            {
              "tag": "TODO",
              "color": "#FF8C00"
            },
            {
              "tag": "FIXME",
              "color": "#FFB6C1"
            },
            {
              "tag": "!",
              "color": "#FF2D00"
            },
            {
              "tag": "?",
              "color": "#3498DB"
            },
            {
              "tag": "*",
              "color": "#98C379"
            }
          ],
          "items": {
            "type": "object",
            "required": [
              "tag",
              "color"
            ],
            "properties": {
              "tag": {
                "type": "string"
              },
              "color": {
                "type": "string"
              },
              "bold": {
                "type": "boolean",
                "default": false
              },
              "italic": {
                "type": "boolean",
                "default": false
              },
              "strikethrough": {
                "type": "boolean",
                "default": false
              },
              "underline": {
                "type": "boolean",
                "default": false
              }
            }
          },
          "description": "Comment tags to highlight. Order defines match priority (earlier wins). Word tags (e.g. TODO) also appear in the Markers sidebar."
        },
        "inline-markers.comments.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.md",
            "**/*.mdx"
          ],
          "description": "Glob patterns of files where comment tag highlighting and scanning are disabled."
        },
        "inline-markers.comments.multilineComments": {
          "type": "boolean",
          "default": true,
          "description": "Enable highlighting inside block comments (/* */) and JSDoc (/** */)."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage"
  ],
  "engines": {
    "vscode": "^1.115.0"
  }
}
