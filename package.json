{
  "name": "inline-markers",
  "displayName": "Inline Markers",
  "version": "0.0.8",
  "description": "",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/f0reth/inline-markers"
  },
  "publisher": "f0reth",
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch",
    "package": "pnpm run lint && node esbuild.js --production",
    "lint": "oxlint --type-aware --type-check",
    "fmt": "oxfmt",
    "bench": "node esbuild.js --bench && vscode-test --config .vscode-test.mjs --label bench",
    "test": "pnpm run compile && vscode-test --label test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "typescript": "^6.0.3"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "inline-markers-bookmarks",
          "title": "Bookmarks",
          "icon": "images/bookmark-sidebar.svg"
        }
      ]
    },
    "views": {
      "inline-markers-bookmarks": [
        {
          "id": "inline-markers.bookmarks",
          "name": "Bookmarks"
        }
      ]
    },
    "commands": [
      {
        "command": "inline-markers.bookmark.toggle",
        "title": "Toggle Bookmark",
        "category": "Inline Markers"
      },
      {
        "command": "inline-markers.bookmark.navigateNext",
        "title": "Next Bookmark",
        "category": "Inline Markers"
      },
      {
        "command": "inline-markers.bookmark.navigatePrevious",
        "title": "Previous Bookmark",
        "category": "Inline Markers"
      },
      {
        "command": "inline-markers.bookmark.clearAll",
        "title": "Clear All Bookmarks",
        "category": "Inline Markers"
      },
      {
        "command": "inline-markers.bookmark.deleteItem",
        "title": "Delete Bookmark",
        "category": "Inline Markers"
      },
      {
        "command": "inline-markers.bookmark.clearFile",
        "title": "Clear File Bookmarks",
        "category": "Inline Markers"
      }
    ],
    "keybindings": [
      {
        "command": "inline-markers.bookmark.toggle",
        "key": "ctrl+alt+k",
        "when": "editorTextFocus"
      },
      {
        "command": "inline-markers.bookmark.navigateNext",
        "key": "ctrl+alt+l",
        "when": "editorTextFocus"
      },
      {
        "command": "inline-markers.bookmark.navigatePrevious",
        "key": "ctrl+alt+j",
        "when": "editorTextFocus"
      },
      {
        "command": "inline-markers.bookmark.clearFile",
        "key": "ctrl+alt+shift+k",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "inline-markers.bookmark.toggle",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "inline-markers.bookmark.deleteItem",
          "when": "viewItem == bookmarkItem",
          "group": "inline"
        },
        {
          "command": "inline-markers.bookmark.clearFile",
          "when": "viewItem == bookmarkFile",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Inline Markers",
      "properties": {
        "inline-markers.gutter.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable diagnostic gutter icons."
        },
        "inline-markers.diagnosticLine.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable diagnostic line messages."
        },
        "inline-markers.diagnosticLine.errorLabelBg": {
          "type": "string",
          "default": "#d32f2f88",
          "description": "Background color for error diagnostic lines."
        },
        "inline-markers.diagnosticLine.warnLabelBg": {
          "type": "string",
          "default": "#ff980088",
          "description": "Background color for warning diagnostic lines."
        },
        "inline-markers.diagnosticLine.errFontColor": {
          "type": "string",
          "default": "#efefef",
          "description": "Text color for error diagnostic lines."
        },
        "inline-markers.diagnosticLine.warnFontColor": {
          "type": "string",
          "default": "#000000",
          "description": "Text color for warning diagnostic lines."
        },
        "inline-markers.diagnosticLine.maxLineLength": {
          "type": "number",
          "default": 120,
          "description": "Maximum length of diagnostic messages."
        },
        "inline-markers.comments.excludeLanguages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "markdown",
            "mdx"
          ],
          "description": "List of language IDs where comment tag highlighting is disabled (e.g. markdown, mdx)."
        },
        "inline-markers.comments.todo.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable TODO comment tags."
        },
        "inline-markers.comments.todo.color": {
          "type": "string",
          "default": "#FF8C00",
          "description": "Color for TODO comment tags."
        },
        "inline-markers.comments.todo.bold": {
          "type": "boolean",
          "default": false,
          "description": "Bold font for TODO comment tags."
        },
        "inline-markers.comments.todo.italic": {
          "type": "boolean",
          "default": false,
          "description": "Italic font for TODO comment tags."
        },
        "inline-markers.comments.todo.strikethrough": {
          "type": "boolean",
          "default": false,
          "description": "Strikethrough decoration for TODO comment tags."
        },
        "inline-markers.comments.todo.underline": {
          "type": "boolean",
          "default": false,
          "description": "Underline decoration for TODO comment tags."
        },
        "inline-markers.comments.fixme.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable FIXME comment tags."
        },
        "inline-markers.comments.fixme.color": {
          "type": "string",
          "default": "#FFB6C1",
          "description": "Color for FIXME comment tags."
        },
        "inline-markers.comments.fixme.bold": {
          "type": "boolean",
          "default": false,
          "description": "Bold font for FIXME comment tags."
        },
        "inline-markers.comments.fixme.italic": {
          "type": "boolean",
          "default": false,
          "description": "Italic font for FIXME comment tags."
        },
        "inline-markers.comments.fixme.strikethrough": {
          "type": "boolean",
          "default": false,
          "description": "Strikethrough decoration for FIXME comment tags."
        },
        "inline-markers.comments.fixme.underline": {
          "type": "boolean",
          "default": false,
          "description": "Underline decoration for FIXME comment tags."
        },
        "inline-markers.comments.important.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable IMPORTANT comment tags."
        },
        "inline-markers.comments.important.color": {
          "type": "string",
          "default": "#FF2D00",
          "description": "Color for IMPORTANT comment tags."
        },
        "inline-markers.comments.important.bold": {
          "type": "boolean",
          "default": false,
          "description": "Bold font for IMPORTANT comment tags."
        },
        "inline-markers.comments.important.italic": {
          "type": "boolean",
          "default": false,
          "description": "Italic font for IMPORTANT comment tags."
        },
        "inline-markers.comments.important.strikethrough": {
          "type": "boolean",
          "default": false,
          "description": "Strikethrough decoration for IMPORTANT comment tags."
        },
        "inline-markers.comments.important.underline": {
          "type": "boolean",
          "default": false,
          "description": "Underline decoration for IMPORTANT comment tags."
        },
        "inline-markers.comments.question.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable QUESTION comment tags."
        },
        "inline-markers.comments.question.color": {
          "type": "string",
          "default": "#3498DB",
          "description": "Color for QUESTION comment tags."
        },
        "inline-markers.comments.question.bold": {
          "type": "boolean",
          "default": false,
          "description": "Bold font for QUESTION comment tags."
        },
        "inline-markers.comments.question.italic": {
          "type": "boolean",
          "default": false,
          "description": "Italic font for QUESTION comment tags."
        },
        "inline-markers.comments.question.strikethrough": {
          "type": "boolean",
          "default": false,
          "description": "Strikethrough decoration for QUESTION comment tags."
        },
        "inline-markers.comments.question.underline": {
          "type": "boolean",
          "default": false,
          "description": "Underline decoration for QUESTION comment tags."
        },
        "inline-markers.comments.highlight.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable HIGHLIGHT comment tags."
        },
        "inline-markers.comments.highlight.color": {
          "type": "string",
          "default": "#98C379",
          "description": "Color for HIGHLIGHT comment tags."
        },
        "inline-markers.comments.highlight.bold": {
          "type": "boolean",
          "default": false,
          "description": "Bold font for HIGHLIGHT comment tags."
        },
        "inline-markers.comments.highlight.italic": {
          "type": "boolean",
          "default": false,
          "description": "Italic font for HIGHLIGHT comment tags."
        },
        "inline-markers.comments.highlight.strikethrough": {
          "type": "boolean",
          "default": false,
          "description": "Strikethrough decoration for HIGHLIGHT comment tags."
        },
        "inline-markers.comments.highlight.underline": {
          "type": "boolean",
          "default": false,
          "description": "Underline decoration for HIGHLIGHT comment tags."
        },
        "inline-markers.comments.multilineComments": {
          "type": "boolean",
          "default": true,
          "description": "Enable highlighting inside block comments (/* */) and JSDoc (/** */)."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage",
    "onView:inline-markers.bookmarks"
  ],
  "engines": {
    "vscode": "^1.115.0"
  }
}
